{
  "name": "playwright-typescript",
  "version": "1.0.0",
  "description": "Playwright-Typescript Framework",
  "license": "ISC",
  "author": "Orhun Akkan",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "load-test:baseline": "artillery run --output load-tests/reports/baseline.json load-tests/configs/baseline.yml && node load-tests/generate-report.cjs",
    "load-test:stress": "artillery run --output load-tests/reports/stress.json load-tests/configs/stress.yml && node load-tests/generate-report.cjs",
    "load-test:report": "node load-tests/generate-report.cjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.65.0",
    "artillery": "^2.0.33",
    "eslint": "^10.7.0",
    "eslint-plugin-playwright": "^2.10.5",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3"
  }
}

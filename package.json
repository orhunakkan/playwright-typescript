{
  "name": "playwright-typescript",
  "version": "1.0.0",
  "description": "Playwright-Typescript Framework",
  "license": "ISC",
  "author": "Orhun Akkan",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:visual": "docker run --rm -v .:/work -w /work --env-file .env mcr.microsoft.com/playwright:v1.58.2-noble npx playwright test tests/e2e/chapter0-visual-regression-tests.spec.ts",
    "test:visual:update": "docker run --rm -v .:/work -w /work --env-file .env mcr.microsoft.com/playwright:v1.58.2-noble npx playwright test tests/e2e/chapter0-visual-regression-tests.spec.ts --update-snapshots"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.2",
    "eslint-plugin-playwright": "^2.10.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
